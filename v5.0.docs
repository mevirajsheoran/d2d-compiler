│               ├── style-guide/
│               │   ├── layout.tsx         — Style guide layout
│               │   └── page.tsx           — Style guide page
│               └── generate/
│                   ├── layout.tsx         — Generation layout
│                   └── page.tsx           — Generation page
└── api/
    ├── generate/route.ts                 — Generation API (if needed)
    ├── project/route.ts                  — Project API proxy
